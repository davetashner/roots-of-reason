{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Age",
  "description": "Age progression definition",
  "type": "object",
  "required": ["id", "name", "index"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "index": { "type": "integer", "minimum": 0 },
    "advance_cost": { "type": "object" },
    "advance_prerequisites": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        { "type": "string", "enum": ["all_previous_age"] }
      ]
    },
    "research_time": { "type": "number", "minimum": 0 },
    "research_multiplier": { "type": "number", "minimum": 0 },
    "flavor_text": { "type": "string" }
  },
  "additionalProperties": false
}
