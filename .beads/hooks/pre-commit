#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v0.57.0 (modified) ---
# Modified: export beads state but do NOT auto-stage issues.jsonl.
# This prevents "bd: backup" noise commits. Run `bd export` and
# `git add .beads/issues.jsonl` manually when you want to commit
# backlog changes (typically as part of a feature PR).
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  bd export --quiet 2>/dev/null || true
fi
# --- END BEADS INTEGRATION ---
